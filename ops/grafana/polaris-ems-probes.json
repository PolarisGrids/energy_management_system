{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Polaris EMS synthetic probe health (spec 018, W5.T49). Every 5 min a CronJob issues ~10 critical reads; this dashboard surfaces pass rate, latency, and critical failures.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Probe pass rate (last 15m)",
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "expr": "1 - (sum(rate(ems_synthetic_probe_errors_total[15m])) / sum(rate(ems_synthetic_probe_duration_seconds_count[15m])))",
          "refId": "A",
          "legendFormat": "pass rate"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 0.95},
              {"color": "green", "value": 0.99}
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Critical probes failing (now)",
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "sum(increase(ems_synthetic_probe_errors_total{endpoint=~\"backend_health|meters_summary|dashboards_index|outages_active|mdms_tariffs_proxy|hes_dcus|alarms_open\"}[15m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "P95 probe latency (30m)",
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ems_synthetic_probe_duration_seconds_bucket[30m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "timeseries",
      "title": "Probe duration p50/p95/p99 by endpoint",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 4},
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(ems_synthetic_probe_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{endpoint}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, endpoint) (rate(ems_synthetic_probe_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{endpoint}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "timeseries",
      "title": "Error rate by endpoint",
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 14},
      "id": 5,
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(ems_synthetic_probe_errors_total[5m]))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error rate by reason",
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 14},
      "id": 6,
      "targets": [
        {
          "expr": "sum by (reason) (rate(ems_synthetic_probe_errors_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Latest probe results",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 24},
      "id": 7,
      "targets": [
        {
          "expr": "sum by (endpoint, result, status) (increase(ems_synthetic_probe_duration_seconds_count[5m]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["polaris-ems", "observability", "spec-018"],
  "templating": {
    "list": [
      {
        "name": "endpoint",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(ems_synthetic_probe_duration_seconds_count, endpoint)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "Asia/Kolkata",
  "title": "Polaris EMS — Synthetic Probes",
  "uid": "polaris-ems-probes",
  "version": 1,
  "weekStart": ""
}
