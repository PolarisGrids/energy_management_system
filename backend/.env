# ── SMOC EMS Backend — Environment Configuration ─────────────────────────────
# Copy this file to .env and fill in real values for production.
# All *_ENABLED flags default to False (mock/demo mode).
# Set to True only when the real service endpoint is reachable.

# ── Core ──────────────────────────────────────────────────────────────────────
APP_NAME=SMOC EMS API
DEBUG=false
SECRET_KEY=smoc-eskom-demo-secret-key-2026-eXtremeLyS3cur3
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://smoc:smoc_pass@db:5432/smoc_ems

# ── HES Integration ───────────────────────────────────────────────────────────
# Set HES_ENABLED=true when sandbox/live HES is available
HES_BASE_URL=http://hes-sandbox:8080/api/v1
HES_API_KEY=hes-demo-api-key-eskom-2026
HES_TIMEOUT_SECONDS=30
HES_ENABLED=false

# ── MDMS Integration ──────────────────────────────────────────────────────────
# Set MDMS_ENABLED=true when sandbox/live MDMS is available
MDMS_BASE_URL=http://mdms-sandbox:8080/api/v1
MDMS_API_KEY=mdms-demo-api-key-eskom-2026
MDMS_TIMEOUT_SECONDS=30
MDMS_ENABLED=false
# Read-only DSN for the MDMS CIS postgres (Alert-Management consumer lookups).
# Leave empty to disable the CIS lookup (UI falls back to locally-tagged consumers).
MDMS_CIS_DB_URL=postgresql+psycopg2://postgres:Q90CNQv0JG6RNtf0@mdms.dev.polagram.in:5432/db_cis

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# KAFKA_SASL_USERNAME=smoc-consumer
# KAFKA_SASL_PASSWORD=kafka-password
KAFKA_CONSUMER_GROUP=smoc-ems-consumer
KAFKA_ENABLED=false

# ── SMTP Email ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=smoc.notifications@polarisgrid.co.za
SMTP_PASSWORD=smoc-smtp-app-password-2026
SMTP_USE_TLS=true
SMTP_ENABLED=false

# ── Twilio SMS ────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=twilio-auth-token-placeholder-2026
TWILIO_FROM_NUMBER=+27100000000
TWILIO_ENABLED=false

# ── Microsoft Teams ───────────────────────────────────────────────────────────
TEAMS_TENANT_ID=eskom-tenant-id-placeholder
TEAMS_CLIENT_ID=smoc-app-client-id-placeholder
TEAMS_CLIENT_SECRET=smoc-app-client-secret-placeholder
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/smoc-demo-webhook
TEAMS_ENABLED=false

# ── Firebase Push Notifications ───────────────────────────────────────────────
FIREBASE_PROJECT_ID=smoc-ems-demo
FIREBASE_SERVER_KEY=firebase-server-key-placeholder
FIREBASE_ENABLED=false

# ── External Systems ──────────────────────────────────────────────────────────
WFM_BASE_URL=http://wfm-service:8080/api/v1
WFM_API_KEY=wfm-api-key-placeholder
WFM_ENABLED=false

CIS_BASE_URL=http://cis-service:8080/api/v1
CIS_API_KEY=cis-api-key-placeholder
CIS_ENABLED=false

GIS_WMS_BASE_URL=https://gis.eskom.co.za/wms
GIS_ENABLED=false
