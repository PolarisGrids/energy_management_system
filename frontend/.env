# ── SMOC EMS Frontend — Environment Configuration ────────────────────────────
# Vite exposes only VITE_* variables to the browser bundle.

# ── API Base URL ──────────────────────────────────────────────────────────────
VITE_API_BASE_URL=/api/v1

# ── Microsoft Teams SDK ───────────────────────────────────────────────────────
# Azure AD app registration for Teams JS SDK (public client — safe in frontend)
VITE_TEAMS_CLIENT_ID=smoc-app-client-id-placeholder
VITE_TEAMS_TENANT_ID=eskom-tenant-id-placeholder
# Teams JS SDK context — set to "teams" when running inside Teams tab app
VITE_TEAMS_CONTEXT=standalone

# ── Mapbox (optional — not used with Leaflet/OSM default) ─────────────────────
VITE_MAPBOX_TOKEN=pk.demo_token_not_needed_for_leaflet

# ── App Metadata ──────────────────────────────────────────────────────────────
VITE_APP_NAME=SMOC EMS
VITE_APP_VERSION=1.0.0
VITE_TENDER_REF=E2136DXLP
